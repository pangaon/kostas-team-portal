# ---- Supabase (Project Settings > API in your Supabase dashboard) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRET — server only, never expose to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# ---- App ----
# Public base URL of the deployed app (used to build invite links).
# Local dev: http://localhost:3000   Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Web Push notifications (so parents don't need WhatsApp) ----
# Generate a key pair once with:   npx web-push generate-vapid-keys
# Paste the PUBLIC key here (also exposed to the browser):
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Paste the PRIVATE key here (SECRET, server only):
VAPID_PRIVATE_KEY=
# Contact URL or mailto for the push service (any valid value):
VAPID_SUBJECT=mailto:coach@example.com
